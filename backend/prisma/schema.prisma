generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int          @id @default(autoincrement())
  // Identidad federada Mastodon: (instancia, id de cuenta) identifica al usuario
  mastodonInstance String
  mastodonId       String
  acct             String
  displayName      String?
  email            String?      @unique
  name             String
  avatar           String?
  phone            String?
  fullName         String?
  bio              String?
  age              Int?
  birthdate        DateTime?
  gender           String?
  // Función "Cerca": celda geohash ~5 km ofuscada EN el cliente (nunca llegan
  // coordenadas reales al servidor). null = no comparte. Caduca a los 7 días.
  nearbyCell       String?
  nearbyUpdatedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  posts            Post[]
  comments         Comment[]
  reactions        Reaction[]
  chats            Chat[]           @relation("UserChats")
  messages         Message[]        @relation("UserMessages")
  forumPosts       ForumPost[]
  forumComments    ForumComment[]
  subforums        SubForum[]       @relation("UserSubforums")
  subforumFollows  SubForumFollow[]
  notifications    Notification[]   @relation("NotificationRecipient")
  notificationActs Notification[]   @relation("NotificationActor")
  marketItems      MarketItem[]     @relation("UserMarketItems")
  media            Media[]

  @@unique([mastodonInstance, mastodonId])
}

model MastodonApp {
  id           Int      @id @default(autoincrement())
  instance     String   @unique
  clientId     String
  clientSecret String
  createdAt    DateTime @default(now())
}

model Post {
  id        Int             @id @default(autoincrement())
  author    User            @relation(fields: [authorId], references: [id])
  authorId  Int
  content   String
  image     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  hashtags  HashtagOnPost[]
  comments  Comment[]
  reactions Reaction[]
  media     Media[]
}

model Hashtag {
  id    Int             @id @default(autoincrement())
  tag   String          @unique
  posts HashtagOnPost[]
}

model HashtagOnPost {
  postId    Int
  hashtagId Int
  post      Post    @relation(fields: [postId], references: [id])
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id])
  @@id([postId, hashtagId])
}

model Comment {
  id        Int        @id @default(autoincrement())
  content   String
  image     String?
  post      Post       @relation(fields: [postId], references: [id])
  postId    Int
  author    User       @relation(fields: [authorId], references: [id])
  authorId  Int
  reactions Reaction[]
  createdAt DateTime   @default(now())
}

// Reacciones cannábicas: una por usuario por post o comentario (HU-RC-001)
enum ReactionType {
  LIKE
  ROLA
  INTERESA
  MOLESTA
}

model Reaction {
  id             Int           @id @default(autoincrement())
  type           ReactionType
  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  post           Post?         @relation(fields: [postId], references: [id])
  postId         Int?
  comment        Comment?      @relation(fields: [commentId], references: [id])
  commentId      Int?
  forumPost      ForumPost?    @relation(fields: [forumPostId], references: [id])
  forumPostId    Int?
  forumComment   ForumComment? @relation(fields: [forumCommentId], references: [id])
  forumCommentId Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@unique([userId, forumPostId])
  @@unique([userId, forumCommentId])
}

model Chat {
  id        Int       @id @default(autoincrement())
  users     User[]    @relation("UserChats")
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    Int
  sender    User     @relation("UserMessages", fields: [senderId], references: [id])
  senderId  Int
  content   String
  createdAt DateTime @default(now())
}

// Foros estilo Reddit: subforos creados por la comunidad, posts con puntaje
// (reacciones: LIKE/ROLA/INTERESA = +1, MOLESTA = -1) e hilos anidados
model SubForum {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  slug        String           @unique
  description String?
  creator     User             @relation("UserSubforums", fields: [creatorId], references: [id])
  creatorId   Int
  posts       ForumPost[]
  followers   SubForumFollow[]
  notifications Notification[]
  createdAt   DateTime         @default(now())
}

model SubForumFollow {
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  subforum   SubForum @relation(fields: [subforumId], references: [id])
  subforumId Int
  createdAt  DateTime @default(now())

  @@id([userId, subforumId])
}

model ForumPost {
  id            Int            @id @default(autoincrement())
  title         String
  content       String
  image         String?
  score         Int            @default(0)
  author        User           @relation(fields: [authorId], references: [id])
  authorId      Int
  subforum      SubForum       @relation(fields: [subforumId], references: [id])
  subforumId    Int
  comments      ForumComment[]
  reactions     Reaction[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([subforumId, createdAt])
  @@index([subforumId, score])
}

model ForumComment {
  id            Int            @id @default(autoincrement())
  content       String
  image         String?
  score         Int            @default(0)
  depth         Int            @default(0)
  deletedAt     DateTime?
  author        User           @relation(fields: [authorId], references: [id])
  authorId      Int
  post          ForumPost      @relation(fields: [postId], references: [id])
  postId        Int
  parent        ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  parentId      Int?
  replies       ForumComment[] @relation("CommentReplies")
  reactions     Reaction[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([postId, parentId])
}

// Centro de notificaciones in-app
enum NotificationType {
  REPLY_POST
  REPLY_COMMENT
  NEW_SUBFORUM_POST
}

model Notification {
  id             Int              @id @default(autoincrement())
  type           NotificationType
  recipient      User             @relation("NotificationRecipient", fields: [recipientId], references: [id])
  recipientId    Int
  actor          User             @relation("NotificationActor", fields: [actorId], references: [id])
  actorId        Int
  subforum       SubForum?        @relation(fields: [subforumId], references: [id])
  subforumId     Int?
  forumPost      ForumPost?       @relation(fields: [forumPostId], references: [id])
  forumPostId    Int?
  forumComment   ForumComment?    @relation(fields: [forumCommentId], references: [id])
  forumCommentId Int?
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([recipientId, readAt])
}

model MarketItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  price       Float
  owner       User     @relation("UserMarketItems", fields: [ownerId], references: [id])
  ownerId     Int
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        Int      @id @default(autoincrement())
  url       String
  post      Post?    @relation(fields: [postId], references: [id])
  postId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  createdAt DateTime @default(now())
}