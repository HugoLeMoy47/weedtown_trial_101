    "/api/nearby/location": {
      "get": {
        "tags": [
          "Cerca"
        ],
        "summary": "Mi estado de compartir zona",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "sharing, cell (geohash-5) y updatedAt"
          }
        }
      },
      "put": {
        "tags": [
          "Cerca"
        ],
        "summary": "Activar/actualizar mi zona (celda de cuadrícula ~2 km ofuscada en el cliente)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Solo acepta la celda ({latIdx}_{lonIdx}, cuadrícula fija de 0.02° ≈ 2 km); cualquier payload con lat/lng/coords se rechaza con 400. La celda caduca a los 7 días.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cell"
                ],
                "properties": {
                  "cell": {
                    "type": "string",
                    "pattern": "^d{1,4}_d{1,5}$"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zona actualizada"
          },
          "400": {
            "description": "Celda inválida o intento de enviar coordenadas"
          }
        }
      },
