{
  "openapi": "3.0.0",
  "info": {
    "title": "WeedTown API",
    "version": "2.4.0",
    "description": "API de WeedTown, red social de la comunidad cannábica de México. Identidad federada con Mastodon (OAuth 2.0) y sesión mediante JWT propio en el header Authorization. Seguridad: headers via helmet, CORS restringido al frontend, rate limiting (300 peticiones/15 min general; 20/15 min en el flujo OAuth), payload JSON limitado a 100 kB e imágenes a 5 MB. El perfil público (GET /api/profile/{id}) no expone PII (email, teléfono, nombre real, edad, nacimiento ni género). Las rutas de mercado y admin son stubs pendientes de implementación."
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT emitido por el backend tras el flujo OAuth de Mastodon (expira en 7 días)."
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "mastodonInstance": {
            "type": "string",
            "example": "mastodon.social"
          },
          "acct": {
            "type": "string",
            "example": "usuario@mastodon.social"
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string"
          },
          "avatar": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "nullable": true
          },
          "birthdate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true,
            "enum": [
              "masculino",
              "femenino",
              "otro",
              null
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "authorId": {
            "type": "integer"
          },
          "content": {
            "type": "string"
          },
          "image": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "avatar": {
                "type": "string",
                "nullable": true
              }
            }
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "postId": {
                  "type": "integer"
                },
                "hashtagId": {
                  "type": "integer"
                },
                "hashtag": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "tag": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "reactions": {
            "$ref": "#/components/schemas/ReactionCounts"
          },
          "myReaction": {
            "$ref": "#/components/schemas/ReactionType"
          },
          "commentCount": {
            "type": "integer"
          }
        }
      },
      "ReactionType": {
        "type": "string",
        "nullable": true,
        "enum": [
          "LIKE",
          "ROLA",
          "INTERESA",
          "MOLESTA"
        ],
        "description": "LIKE = Me gusta, ROLA = Me rola, INTERESA = Me interesa, MOLESTA = Me molesta"
      },
      "ReactionCounts": {
        "type": "object",
        "properties": {
          "LIKE": {
            "type": "integer"
          },
          "ROLA": {
            "type": "integer"
          },
          "INTERESA": {
            "type": "integer"
          },
          "MOLESTA": {
            "type": "integer"
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "postId": {
            "type": "integer"
          },
          "content": {
            "type": "string"
          },
          "image": {
            "type": "string",
            "nullable": true,
            "description": "URL de imagen adjunta (opcional)"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "avatar": {
                "type": "string",
                "nullable": true
              }
            }
          },
          "reactions": {
            "$ref": "#/components/schemas/ReactionCounts"
          },
          "myReaction": {
            "$ref": "#/components/schemas/ReactionType"
          }
        }
      },
      "ProfileInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "example": "+521234567890"
          },
          "fullName": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "age": {
            "type": "integer",
            "minimum": 0,
            "maximum": 120
          },
          "birthdate": {
            "type": "string",
            "format": "date"
          },
          "gender": {
            "type": "string",
            "enum": [
              "masculino",
              "femenino",
              "otro",
              ""
            ]
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Sistema"
    },
    {
      "name": "Auth",
      "description": "Identidad federada con Mastodon"
    },
    {
      "name": "Posts"
    },
    {
      "name": "Reacciones",
      "description": "Reacciones cannábicas: Me gusta, Me rola, Me interesa, Me molesta — una por usuario por objeto"
    },
    {
      "name": "Comentarios"
    },
    {
      "name": "Media",
      "description": "Subida de imágenes anonimizadas"
    },
    {
      "name": "Foros",
      "description": "Foros estilo Reddit: subforos, puntaje por reacciones, hilos a 3 niveles"
    },
    {
      "name": "Notificaciones",
      "description": "Centro de notificaciones in-app"
    },
    {
      "name": "Perfil"
    },
    {
      "name": "Pendientes",
      "description": "Stubs sin lógica real todavía (foro, chat, market, admin)"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Sistema"
        ],
        "summary": "Estado del proceso y conexión a la base de datos",
        "responses": {
          "200": {
            "description": "Proceso y BD operativos"
          },
          "503": {
            "description": "Proceso vivo pero sin conexión a la BD"
          }
        }
      }
    },
    "/api/auth/mastodon/start": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Inicia el flujo OAuth con una instancia de Mastodon",
        "description": "Registra dinámicamente la app en la instancia si es la primera vez y redirige a su pantalla de autorización con un state firmado (expira en 10 minutos).",
        "parameters": [
          {
            "name": "instance",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "mastodon.social"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirección a https://{instance}/oauth/authorize"
          },
          "400": {
            "description": "Instancia inválida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/mastodon/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Callback OAuth (uso interno del flujo)",
        "description": "Canjea el código por un access token, obtiene el perfil con verify_credentials, hace upsert del usuario y redirige al frontend con el JWT en el fragmento: {FRONTEND_URL}/auth/callback#token=...",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirección al frontend con el token, o a /login?error=... si falla"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Usuario de la sesión actual",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "Sin token o token inválido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/posts": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Feed paginado de posteos (20 por página)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Página del feed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "posts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Post"
                      }
                    },
                    "page": {
                      "type": "integer"
                    },
                    "totalPages": {
                      "type": "integer"
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Posts"
        ],
        "summary": "Crear posteo (el autor sale del token)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string"
                  },
                  "image": {
                    "type": "string",
                    "description": "URL de imagen (opcional)"
                  },
                  "hashtags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "cultura",
                      "420",
                      "cdmx"
                    ]
                  }
                },
                "required": [
                  "content"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Posteo creado con autor y hashtags",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Post"
                }
              }
            }
          },
          "400": {
            "description": "Faltan campos requeridos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "No autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/posts/search": {
      "get": {
        "tags": [
          "Posts"
        ],
        "summary": "Buscar posteos por contenido o nombre de autor",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resultados de búsqueda",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Post"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/profile/me": {
      "get": {
        "tags": [
          "Perfil"
        ],
        "summary": "Perfil propio",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil del usuario autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "No autenticado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Perfil"
        ],
        "summary": "Actualizar perfil propio",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Perfil actualizado"
          },
          "400": {
            "description": "Errores de validación"
          },
          "401": {
            "description": "No autenticado"
          }
        }
      }
    },
    "/api/profile/{id}": {
      "get": {
        "tags": [
          "Perfil"
        ],
        "summary": "Perfil público por id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil del usuario",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "description": "Usuario no encontrado"
          }
        }
      }
    },
    "/api/posts/{id}/reaction": {
      "post": {
        "tags": [
          "Reacciones"
        ],
        "summary": "Reaccionar a un posteo (misma reacción = quitar, distinta = reemplazar)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "$ref": "#/components/schemas/ReactionType"
                  }
                },
                "required": [
                  "type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reacción registrada; devuelve myReaction y conteos frescos"
          },
          "400": {
            "description": "Tipo de reacción inválido"
          },
          "401": {
            "description": "No autenticado"
          },
          "404": {
            "description": "Post no encontrado"
          }
        }
      },
      "delete": {
        "tags": [
          "Reacciones"
        ],
        "summary": "Quitar la reacción propia de un posteo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reacción eliminada; devuelve conteos frescos"
          },
          "401": {
            "description": "No autenticado"
          }
        }
      }
    },
    "/api/posts/{id}/like": {
      "post": {
        "tags": [
          "Reacciones"
        ],
        "summary": "Alias de compatibilidad: equivale a reaccionar con LIKE",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reacción LIKE registrada (o quitada si ya existía)"
          },
          "401": {
            "description": "No autenticado"
          }
        }
      }
    },
    "/api/posts/{id}/comment": {
      "post": {
        "tags": [
          "Comentarios"
        ],
        "summary": "Comentar un posteo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string"
                  }
                },
                "required": [
                  "content"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comentario creado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "400": {
            "description": "Comentario vacío"
          },
          "401": {
            "description": "No autenticado"
          },
          "404": {
            "description": "Post no encontrado"
          }
        }
      }
    },
    "/api/posts/{id}/comments": {
      "get": {
        "tags": [
          "Comentarios"
        ],
        "summary": "Listar comentarios de un posteo (con conteos de reacciones)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Comentarios del post",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "comments": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Comment"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/media/upload": {
      "post": {
        "tags": [
          "Media"
        ],
        "summary": "Subir una imagen (para post o comentario)",
        "description": "Multipart/form-data con campo 'image'. Máx. 5 MB; formatos JPG, PNG o WebP. El cliente debe enviar la imagen ya anonimizada (sin EXIF/GPS); el archivo se guarda con nombre aleatorio y se devuelve su URL.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "image"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Imagen almacenada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Archivo demasiado grande o formato no permitido"
          },
          "401": {
            "description": "No autenticado"
          }
        }
      }
    },
    "/api/comments/{id}/reaction": {
      "post": {
        "tags": [
          "Reacciones"
        ],
        "summary": "Reaccionar a un comentario (misma reacción = quitar, distinta = reemplazar)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "$ref": "#/components/schemas/ReactionType"
                  }
                },
                "required": [
                  "type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reacción registrada; devuelve myReaction y conteos frescos"
          },
          "400": {
            "description": "Tipo de reacción inválido"
          },
          "401": {
            "description": "No autenticado"
          },
          "404": {
            "description": "Comentario no encontrado"
          }
        }
      },
      "delete": {
        "tags": [
          "Reacciones"
        ],
        "summary": "Quitar la reacción propia de un comentario",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reacción eliminada; devuelve conteos frescos"
          },
          "401": {
            "description": "No autenticado"
          }
        }
      }
