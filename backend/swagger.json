        "tags": [
          "Cerca"
        ],
        "summary": "Dejar de compartir (borra la celda)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "sharing=false"
          }
        }
      }
    },
