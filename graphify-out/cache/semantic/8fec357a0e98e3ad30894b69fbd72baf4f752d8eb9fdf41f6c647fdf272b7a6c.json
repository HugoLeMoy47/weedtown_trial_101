{"nodes": [{"id": "readme_weedtown", "label": "WeedTown", "file_type": "document", "source_file": "README.md", "source_location": "L1-L3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Red social para la comunidad cannabica de Mexico: espacio seguro, con respeto y sin estigma; mercado comunitario legal en fase posterior, nunca compraventa de sustancias."}, {"id": "readme_identidad_federada_mastodon", "label": "Identidad federada via Mastodon", "file_type": "rationale", "source_file": "README.md", "source_location": "L9,L93-L95", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Seguridad primero: WeedTown no crea contrasenas ni exige email; seudonimato por diseno, la identidad unica es (mastodonInstance, mastodonId). Multi-instancia: la app se registra dinamicamente en cada instancia (tabla MastodonApp)."}, {"id": "readme_flujo_oauth_mastodon", "label": "Flujo OAuth 2.0 de Mastodon", "file_type": "concept", "source_file": "README.md", "source_location": "L69-L90", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "readme_sesion_jwt", "label": "Sesion JWT", "file_type": "concept", "source_file": "README.md", "source_location": "L95", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "JWT propio firmado con JWT_SECRET (7 dias) enviado como Authorization: Bearer; el state de OAuth tambien va firmado (anti-CSRF, expira en 10 minutos)."}, {"id": "readme_endurecimiento_backend", "label": "Endurecimiento del backend", "file_type": "rationale", "source_file": "README.md", "source_location": "L97-L105", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "helmet con CORP cross-origin para servir /uploads; CORS estricto a FRONTEND_URL; rate limit 300/15min (20/15min en OAuth); payload JSON <=100kB e imagenes <=5MB; el perfil publico no expone PII; errores sanitizados hacia el cliente."}, {"id": "readme_cerca_descubrimiento_por_zonas", "label": "Cerca: descubrimiento por zonas con privacidad", "file_type": "rationale", "source_file": "README.md", "source_location": "L225-L234", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "El navegador convierte el GPS a celda geohash de ~5 km antes de enviar nada; el servidor nunca ve coordenadas y el endpoint las rechaza. Cuadricula fija (nada que triangular), acceso reciproco, la celda caduca a los 7 dias, mapa Leaflet+OSM con zonas agregadas sin pins individuales, rate limit anti-scraping."}, {"id": "readme_chat_tiempo_real", "label": "Chat 1 a 1 en tiempo real", "file_type": "concept", "source_file": "README.md", "source_location": "L236-L238", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "El envio entra por REST (hereda auth, rate limit y validacion) y la entrega en vivo sale por Socket.IO; handshake autenticado con JWT y sala personal user:{id} para todas las sesiones abiertas."}, {"id": "readme_foros_estilo_reddit", "label": "Foros estilo Reddit", "file_type": "concept", "source_file": "README.md", "source_location": "L240", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Las reacciones son el voto (positivas +1, Me molesta -1); orden Relevante usa score/(horas+2)^1.5 con decaimiento temporal; hilos anidados hasta 3 niveles (mas profundo se aplana con 'en respuesta a @usuario')."}, {"id": "readme_reacciones_cannabicas", "label": "Reacciones cannabicas", "file_type": "concept", "source_file": "README.md", "source_location": "L30,L197", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cuatro tipos: LIKE, ROLA, INTERESA, MOLESTA; repetir la misma la quita, una distinta la reemplaza."}, {"id": "readme_notificaciones_in_app", "label": "Notificaciones in-app", "file_type": "concept", "source_file": "README.md", "source_location": "L34,L212,L240", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Se disparan por respuesta a tu post, respuesta a tu comentario y post nuevo en subforos seguidos; campana con contador."}, {"id": "readme_mercado_comunitario", "label": "Mercado comunitario", "file_type": "concept", "source_file": "README.md", "source_location": "L11,L253-L254", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fase 2: catalogo de tangibles e intangibles licitos (merch, arte, glass, talleres, cursos, servicios); explicitamente NO para compraventa de sustancias; el modelo MarketItem existente evolucionara hacia este diseno."}, {"id": "readme_panel_moderacion", "label": "Panel administrativo / moderacion", "file_type": "concept", "source_file": "README.md", "source_location": "L40,L251", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Planificado antes del mercado: rol de usuario, reportes, ocultar/suspender; se integrara al frontend en /admin. Las rutas admin existen como stubs."}, {"id": "readme_ui_material_design", "label": "UI Material Design claro/oscuro", "file_type": "concept", "source_file": "README.md", "source_location": "L12,L116,L123", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Minimalismo funcional y accesibilidad. MUI fijado en v5 porque la v9 es incompatible con Create React App (react-scripts 5); no actualizar de major sin migrar el bundler."}, {"id": "readme_postgresql_supabase", "label": "PostgreSQL en Supabase", "file_type": "concept", "source_file": "README.md", "source_location": "L115,L131-L135", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Supabase solo para dev/pruebas; en produccion cualquier PostgreSQL cambiando DATABASE_URL (pooler transaccion, puerto 6543) y DIRECT_URL (sesion, puerto 5432, para migraciones)."}, {"id": "readme_prisma_orm", "label": "Prisma ORM", "file_type": "concept", "source_file": "README.md", "source_location": "L51,L115", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "readme_socket_io", "label": "Socket.IO", "file_type": "concept", "source_file": "README.md", "source_location": "L119", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "readme_swagger_ui", "label": "Swagger UI en /api-docs", "file_type": "concept", "source_file": "README.md", "source_location": "L118,L186", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "readme_arquitectura_monorepo", "label": "Arquitectura monorepo de cuatro modulos", "file_type": "concept", "source_file": "README.md", "source_location": "L45-L67", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "backend (Express+Prisma), frontend (React 18 + CRA + MUI v5), mobile (Expo, demo) y admin-panel (pendiente)."}], "edges": [{"source": "readme_weedtown", "target": "readme_identidad_federada_mastodon", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "L9", "weight": 1.0}, {"source": "readme_flujo_oauth_mastodon", "target": "readme_identidad_federada_mastodon", "relation": "implements", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "L69-L95", "weight": 1.0}, {"source": "readme_flujo_oauth_mastodon", "target": "readme_sesion_jwt", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "L87-L95", "weight": 1.0}, {"source": "readme_chat_tiempo_real", "target": "readme_socket_io", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "L236-L238", "weight": 1.0